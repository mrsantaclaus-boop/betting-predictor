# ─────────────────────────────────────────────────────────
#  SAI Tipster — Cloud Environment Variables
#  Copy this as .env when deploying, or set in Render dashboard
# ─────────────────────────────────────────────────────────

# LLM — Groq free tier (https://console.groq.com)
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Football data — free (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API-Football — used for Brasileirao + WCQ (https://dashboard.api-football.com/register)
API_FOOTBALL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Odds — free 500 req/month (https://the-odds-api.com/#get-access)
ODDS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# News — free 100 req/day (https://newsapi.org/register)
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GNews — free 100 req/day (https://gnews.io/register)
GNEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Internal (don't change)
MIROFISH_API_URL=http://localhost:5001
PORT=8080
FLASK_ENV=production
LOCAL_ZEP_DB_PATH=/app/data/local_memory.db
CACHE_DB_PATH=/app/data/cache.db
